SSH_PORT=6922
HTTP_PORT=8080
SSHCHAT_PORT=2022
DATA_DIR=./data

# Logto OAuth — set all five vars to enable browser-based identity binding.
# Leave LOGTO_ENDPOINT blank to use SSH-key-based nick registration instead.
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_REDIRECT_URI=
HTTP_LISTEN_ADDR=0.0.0.0:8080

# tobby IRC client target. Defaults baked into the image; override here to
# point at a different network (e.g. the ergo server with Logto integration).
IRC_SERVER=irc.h4ks.com
IRC_PORT=6697
IRC_CHANNEL="#dev"

SHOP_API_URL=http://localhost:3005
